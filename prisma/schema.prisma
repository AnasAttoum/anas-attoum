generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Skill {
  id      String  @id @default(uuid())
  order   Int
  name    String
  color   String
  image   String
  enabled Boolean @default(true)

  createdAt DateTime @default(now())
}

enum projectType {
  project
  page
  game
  component
}

model Project {
  id             String      @id @default(uuid())
  order          Int
  name           String
  type           projectType
  code           String
  demo           String
  description_de String
  description_en String
  technologies   String[]
  video          String
  image          String
  mockup         String
  logo           String
  enabled        Boolean     @default(true)

  createdAt DateTime @default(now())
}

model Information {
  id                  String @id @default(uuid())
  title_de            String
  title_en            String
  subTitle_de         String
  subTitle_en         String
  about_de            String
  about_en            String
  anas_attoum_1       String
  anas_attoum_2       String
  cv_de               String
  cv_en               String
  contact_title_de    String
  contact_title_en    String
  contact_subTitle_de String
  contact_subTitle_en String

  createdAt DateTime @default(now())
}

model SocialMedia {
  id    String @id @default(uuid())
  order Int
  alt   String
  image   String
  href  String

  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
}
